{
  "name": "@quilla-kit/security",
  "version": "0.1.0",
  "description": "Security primitives: Token/TokenService, PasswordHasher, SessionStore interfaces, and auth middlewares (Bearer-token verification + authenticated-session enrichment) that plug into @quilla-kit/http's Router.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-kit/tree/main/packages/security",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quilla-kit/quilla-kit.git",
    "directory": "packages/security"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-kit/issues"
  },
  "keywords": [
    "security",
    "authentication",
    "authorization",
    "jwt",
    "token",
    "session",
    "password",
    "bearer",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@quilla-kit/errors": "workspace:^",
    "@quilla-kit/execution-context": "workspace:^",
    "@quilla-kit/http": "workspace:^",
    "@quilla-kit/observability": "workspace:^"
  }
}
