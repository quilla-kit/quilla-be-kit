{
  "name": "@quilla-kit/http",
  "version": "0.1.0",
  "description": "Transport-agnostic HTTP abstractions: IHttpRequest, IWebServer, and @Controller/@Route/@Authorize/@ValidateRequest decorators.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-kit/tree/main/packages/http",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quilla-kit/quilla-kit.git",
    "directory": "packages/http"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-kit/issues"
  },
  "keywords": ["http", "decorators", "controller", "routing", "typescript"],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@quilla-kit/execution-context": "workspace:^",
    "@quilla-kit/observability": "workspace:^"
  }
}
