{
  "name": "@quilla-be-kit/runtime",
  "version": "0.2.1",
  "description": "Process runtime: phased ShutdownManager, OS-signal / uncaught-error bridge that owns process.exit, and a transport-agnostic ComponentRegistry.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-be-kit/tree/main/packages/runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quilla-kit/quilla-be-kit.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-be-kit/issues"
  },
  "keywords": [
    "runtime",
    "shutdown",
    "graceful-shutdown",
    "lifecycle",
    "signals",
    "component-registry",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "vitest": "^2.1.3"
  }
}
