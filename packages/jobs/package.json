{
  "name": "@quilla-kit/jobs",
  "version": "0.1.0",
  "description": "Background-job interfaces + in-process job runner. Register scheduled jobs, run each tick inside a system execution context, shut down cleanly via Disposable.",
  "license": "MIT",
  "author": "Max Martinez",
  "homepage": "https://github.com/quilla-kit/quilla-kit/tree/main/packages/jobs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quilla-kit/quilla-kit.git",
    "directory": "packages/jobs"
  },
  "bugs": {
    "url": "https://github.com/quilla-kit/quilla-kit/issues"
  },
  "keywords": ["jobs", "background-jobs", "scheduler", "job-runner", "typescript"],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@quilla-kit/execution-context": "workspace:^",
    "@quilla-kit/observability": "workspace:^",
    "@quilla-kit/runtime": "workspace:^"
  }
}
